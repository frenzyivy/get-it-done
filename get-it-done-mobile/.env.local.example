# URL of the deployed Next.js web app. Mobile calls /api/ai/* here.
# For local dev against `next dev`, use your machine's LAN IP (e.g. http://192.168.1.10:3000),
# not localhost — the emulator/simulator can't reach the host via localhost.
EXPO_PUBLIC_WEB_URL=https://your-app.vercel.app
